# Variáveis lidas pelo docker-compose.yaml.
# No Coolify você NÃO precisa preencher estas — ele gera automaticamente.
# Use este arquivo só para rodar localmente (docker compose up) ou para
# entender o que cada placeholder significa.

# Domínio público do painel admin. No Coolify isto vira SERVICE_FQDN_OPENMU_8080.
# Localmente, use algo como http://localhost:8080
SERVICE_FQDN_OPENMU_8080=http://localhost:8080

# Senha do superusuário do Postgres. No Coolify é gerada automaticamente.
# Localmente, defina uma senha forte aqui.
SERVICE_PASSWORD_POSTGRES=trocar-por-senha-forte
